<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans  
               http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">
               
               
     <bean id="empA" class="com.my.spring.model.Employee2">
		<lookup-method  bean="address2" name="applyAddress"/>
	
	</bean>


	 <bean id="address2" class="com.my.spring.model.Address2" scope="prototype">
		<property name="city" value="salimar"></property>
		<property name="state" value="Delhi"></property>
	  </bean>
	
	
	
</beans>